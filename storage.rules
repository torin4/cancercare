rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to validate file type (only allow medical document types)
    function isValidMedicalFileType() {
      return request.resource.contentType.matches('application/pdf') ||
             request.resource.contentType.matches('image/.*') ||
             request.resource.contentType.matches('application/msword') ||
             request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.wordprocessingml.document') ||
             request.resource.contentType.matches('text/plain') ||
             request.resource.contentType.matches('application/dicom') ||
             request.resource.contentType.matches('application/x-dicom') ||
             request.resource.contentType.matches('application/zip') ||
             request.resource.contentType.matches('application/x-zip-compressed');
    }
    
    // Helper function to validate file extension
    // Allow files with valid extensions OR files without extensions (for DICOM files from ZIP archives)
    function hasValidExtension() {
      // Check if file has a valid extension
      let hasExtension = request.resource.name.matches('.*\\.(pdf|PDF|jpg|jpeg|JPG|JPEG|png|PNG|gif|doc|DOC|docx|DOCX|txt|TXT|dcm|DCM|dicom|DICOM|zip|ZIP)$');
      
      // Also allow files without extensions (common for DICOM files extracted from ZIP)
      // These will be validated by content type instead
      let noExtension = !request.resource.name.matches('.*\\..*');
      
      return hasExtension || noExtension;
    }
    
    // Helper function to check file size (500MB max, 1KB min - increased for DICOM ZIP files)
    function isValidFileSize() {
      return request.resource.size > 1024 && // At least 1KB
             request.resource.size < 500 * 1024 * 1024; // Max 500MB (for large DICOM ZIP archives)
    }
    
    // Helper function to ensure user owns the path
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Documents - users can only access files in their own directory
    // Enhanced security with file type validation and size limits
    match /documents/{userId}/{allPaths=**} {
      // Read: Only authenticated owner can read their files
      // Note: No extension validation for reads - files may have been uploaded without extensions
      allow read: if isOwner(userId);
      
      // Write: Only authenticated owner can upload, with strict validation
      // Allow files with valid extensions OR files without extensions (for DICOM files)
      allow write: if isOwner(userId) &&
                      isValidFileSize() &&
                      isValidMedicalFileType() &&
                      hasValidExtension();
      
      // Delete: Only authenticated owner can delete their files
      allow delete: if isOwner(userId);
      
      // List: Only authenticated owner can list their files
      allow list: if isOwner(userId);
    }
    
    // Profile images - users can only access their own profile images
    // Allow image files only, with size limits
    match /profile-images/{userId}/{allPaths=**} {
      // Read: Only authenticated owner can read their profile images
      allow read: if isOwner(userId);
      
      // Write: Only authenticated owner can upload profile images (images only, max 5MB)
      // Support common image formats including HEIC/HEIF from Apple devices
      allow write: if isOwner(userId) &&
                      request.resource.size > 1024 && // At least 1KB
                      request.resource.size < 5 * 1024 * 1024 && // Max 5MB for profile images
                      request.resource.contentType.matches('image/.*') &&
                      request.resource.name.matches('.*\\.(jpg|jpeg|JPG|JPEG|png|PNG|gif|GIF|heic|HEIC|heif|HEIF|webp|WEBP)$');
      
      // Delete: Only authenticated owner can delete their profile images
      allow delete: if isOwner(userId);
      
      // List: Only authenticated owner can list their profile images
      allow list: if isOwner(userId);
    }
    
    // Deny all other paths by default
    match /{allPaths=**} {
      allow read, write, delete, list: if false;
    }
  }
}
